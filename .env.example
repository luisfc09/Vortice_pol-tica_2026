# Vórtice — variáveis de ambiente
# Copie este arquivo para .env e preencha.

# ============================================================================
# Modo demonstração (sem Supabase)
# ----------------------------------------------------------------------------
# Quando true, todo o app roda contra dados em localStorage.
# Útil para dev local sem internet ou para mostrar o produto sem provisionar nada.
VITE_USE_MOCKS=true

# ============================================================================
# Supabase — preencha quando VITE_USE_MOCKS=false
# ----------------------------------------------------------------------------
# Pegue em: Supabase Dashboard > seu projeto > Settings > API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ============================================================================
# Backend Express (proxy/cache dos dados do TSE) — usado pelo Mapa político
# ----------------------------------------------------------------------------
# Dev local: http://localhost:3001 (rode `npm run dev` na pasta backend/).
# Produção: a URL pública do backend no Railway.
# Se não definir, o frontend assume http://localhost:3001.
VITE_BACKEND_URL=http://localhost:3001
