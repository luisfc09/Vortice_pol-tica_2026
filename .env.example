# Vórtice — variáveis de ambiente
# Copie este arquivo para .env e preencha.

# ============================================================================
# Modo demonstração (sem Supabase)
# ----------------------------------------------------------------------------
# Quando true, todo o app roda contra dados em localStorage.
# Útil para dev local sem internet ou para mostrar o produto sem provisionar nada.
VITE_USE_MOCKS=true

# ============================================================================
# Supabase — preencha quando VITE_USE_MOCKS=false
# ----------------------------------------------------------------------------
# Pegue em: Supabase Dashboard > seu projeto > Settings > API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ============================================================================
# Backend Express (TSE) — OPCIONAL
# ----------------------------------------------------------------------------
# O Mapa político (modo Eleições/TSE) fala DIRETO com o Supabase via RPCs —
# não precisa do backend em produção. O backend Express em backend/ existe
# só pra dev local e pro importer CLI (npm run import:tse). Esta variável
# não é mais usada pelo frontend.
# VITE_BACKEND_URL=http://localhost:3001
