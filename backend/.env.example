# Porta do servidor. Default 3001.
PORT=3001

# Origem(ns) liberadas no CORS além de http://localhost:3000/5173. Útil em
# produção pra liberar o domínio do frontend (ex.: o app no Railway).
FRONTEND_URL=https://vorticepol-tica2026-production.up.railway.app

# (Opcional) Tempo do cache em segundos. Default 86400 (24h) — dados
# históricos do TSE não mudam, então o cache pode ser bem agressivo.
# CACHE_TTL_SECONDS=86400
